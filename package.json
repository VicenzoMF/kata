{
  "name": "kata-monorepo",
  "version": "0.0.0",
  "private": true,
  "license": "Apache-2.0",
  "author": "Vicenzo Frusciante",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --filter=./packages/* build",
    "pretypecheck": "pnpm --filter=kata build",
    "typecheck": "pnpm -r typecheck",
    "prepare": "lefthook install",
    "format": "biome check --write .",
    "format:check": "biome check .",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:hooks": "bash .codex/hooks/lib/extract-write-paths.test.sh && bash .codex/hooks/acceptance.test.sh",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm test:hooks",
    "dev:hello": "pnpm --filter=hello dev",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@vitest/coverage-v8": "^4.1.7",
    "kata": "workspace:*",
    "lefthook": "^2.1.8",
    "oxlint": "^1.66.0",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.7"
  }
}
