{
  "name": "@kata/verify",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify": "tsx src/main.ts",
    "verify:json": "tsx src/main.ts --json"
  },
  "dependencies": {
    "typescript": "^5.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsx": "^4.19"
  }
}
