{
  "name": "katajs",
  "version": "0.1.0",
  "description": "An opinionated, type-safe web framework on Hono — static DI, mandatory Zod input/output schemas, no-codegen RPC, and a verifiable folder layout.",
  "keywords": [
    "hono",
    "web-framework",
    "framework",
    "typescript",
    "type-safe",
    "zod",
    "dependency-injection",
    "rpc",
    "esm",
    "api",
    "backend",
    "http"
  ],
  "license": "Apache-2.0",
  "author": "Vicenzo Frusciante",
  "homepage": "https://github.com/VicenzoMF/kata#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VicenzoMF/kata.git",
    "directory": "packages/kata"
  },
  "bugs": {
    "url": "https://github.com/VicenzoMF/kata/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./jwt": {
      "types": "./dist/jwt/index.d.ts",
      "import": "./dist/jwt/index.js"
    },
    "./node": {
      "types": "./dist/node/index.d.ts",
      "import": "./dist/node/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "kata": "./dist/cli/main.js",
    "katajs": "./dist/cli/main.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepare": "tsup",
    "prepublishOnly": "pnpm run build && pnpm run typecheck"
  },
  "peerDependencies": {
    "hono": "^4",
    "typescript": "^5",
    "zod": "^3"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "devDependencies": {
    "@kata/verify": "workspace:*",
    "@types/node": "^20",
    "hono": "^4",
    "tsup": "^8",
    "typescript": "^5.6",
    "zod": "^3"
  }
}
